# PostgreSQL direct connection string for Supabase.
# Found in Supabase: Project Settings > Database > Connection string > URI.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Secret used to sign admin JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Port the Go API listens on.
PORT=8080
